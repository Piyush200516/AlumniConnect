generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Core user model — single table for all roles with role-based auth
model User {
  id                         String              @id @default(uuid())
  email                      String              @unique
  password                   String
  role                       Role
  status                     AccountStatus       @default(ACTIVE)
  isEmailVerified            Boolean             @default(false)
  emailVerifyToken           String?             @unique
  emailVerifyExpiry          DateTime?
  resetToken                 String?             @unique
  resetTokenExpiry           DateTime?
  lastLoginAt                DateTime?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  alumniProfile              AlumniProfile?
  studentProfile             StudentProfile?
  studentApplication         StudentApplication?
  cdcProfile                 CdcProfile?
  comments                   Comment[]
  conversationsAsUser1       Conversation[]      @relation("ConversationUser1")
  conversationsAsUser2       Conversation[]      @relation("ConversationUser2")
  eventRegistrations         EventRegistration[]
  createdEvents              Event[]
  eventCertificates          EventCertificate[]  @relation("StudentCertificates")
  jobApplications            JobApplication[]
  postedJobs                 Job[]
  savedJobs                  SavedJob[]
  likes                      Like[]
  receivedMentorshipRequests MentorshipRequest[] @relation("MentorshipAlumni")
  sentMentorshipRequests     MentorshipRequest[] @relation("MentorshipStudent")
  sentMessages               Message[]
  notifications              Notification[]
  posts                      Post[]
  connectionsSent            Connection[]        @relation("ConnectionSender")
  connectionsReceived        Connection[]        @relation("ConnectionReceiver")
  followers                  User[]              @relation("UserFollows")
  following                  User[]              @relation("UserFollows")
  savedAlumni                SavedAlumni[]       @relation("UserSavedAlumni")
  savedByUsers               SavedAlumni[]       @relation("AlumniSavedBy")

  @@index([role])
  @@index([status])
  @@index([email])
  @@map("users")
}

/// Student profile — linked 1:1 with User (role = STUDENT)
model StudentProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  fullName         String
  enrollmentNumber String   @unique
  branch           String
  course           String
  graduationYear   Int
  skills           String[] @default([])
  bio              String?
  phone            String?
  linkedinUrl      String?
  githubUrl        String?
  resumeUrl        String?
  profileImage     String?
  isVerified         Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([branch])
  @@index([graduationYear])
  @@index([course])
  @@map("student_profiles")
}

/// Alumni profile — linked 1:1 with User (role = ALUMNI)
model AlumniProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  fullName        String
  passingYear     Int
  branch          String?
  course          String?
  currentCompany  String?
  designation     String?
  industry        String?
  /// Years of experience
  experience      Int?
  skills          String[] @default([])
  bio             String?
  /// Cloudinary URL
  profileImageUrl String?
  linkedinUrl     String?
  location        String?
  companyId       String?
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  workExperiences WorkExperience[]
  education       Education[]
  skillsList      Skill[]          @relation("AlumniSkills")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([passingYear])
  @@index([industry])
  @@index([currentCompany])
  @@index([companyId])
  @@map("alumni_profiles")
}

/// CDC (College Development Cell) profile — linked 1:1 with User (role = CDC)
model CdcProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  collegeName   String
  department    String
  officialEmail String
  contactNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cdc_profiles")
}

/// Posts created by Alumni or CDC users
model Post {
  id        String    @id @default(uuid())
  authorId  String
  content   String
  /// Cloudinary URL
  imageUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
  likes     Like[]
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

/// Comments on posts
model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@map("comments")
}

/// Likes on posts — unique constraint prevents duplicate likes
model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

/// Mentorship request from a Student to an Alumni
model MentorshipRequest {
  id        String           @id @default(uuid())
  studentId String
  alumniId  String
  status    MentorshipStatus @default(PENDING)
  /// Optional message from student
  message   String?
  /// Optional note from alumni on accept/reject
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  alumni    User             @relation("MentorshipAlumni", fields: [alumniId], references: [id], onDelete: Cascade)
  student   User             @relation("MentorshipStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, alumniId])
  @@index([studentId])
  @@index([alumniId])
  @@index([status])
  @@index([createdAt])
  @@map("mentorship_requests")
}

/// Job or internship posted by Alumni
model Job {
  id             String           @id @default(uuid())
  postedById     String
  title          String
  description    String
  company        String
  companyLogo    String?
  location       String?
  salary         String?
  jobType        JobType          @default(FULL_TIME)
  skillsRequired String[]         @default([])
  deadline       DateTime?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  // Detailed fields
  responsibilities String?
  eligibility      String?
  benefits         String?
  selectionProcess String?
  applicationLink  String?
  
  // CDC verification fields
  approvalStatus   JobApprovalStatus @default(PENDING)
  remarks          String?
  
  applications     JobApplication[]
  postedBy         User              @relation(fields: [postedById], references: [id], onDelete: Cascade)
  savedBy          SavedJob[]

  @@index([postedById])
  @@index([jobType])
  @@index([isActive])
  @@index([deadline])
  @@index([createdAt(sort: Desc)])
  @@map("jobs")
}

/// Student application for a job
model JobApplication {
  id          String            @id @default(uuid())
  jobId       String
  applicantId String
  /// Cloudinary URL
  resumeUrl   String
  coverLetter String?
  status      ApplicationStatus @default(APPLIED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  applicant   User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
  @@index([status])
  @@index([createdAt])
  @@map("job_applications")
}

/// Events created by CDC or Alumni
model Event {
  id                   String              @id @default(uuid())
  createdById          String
  title                String
  description          String
  bannerUrl            String?             // Cloudinary URL
  category             String              // EventCategory
  mode                 EventMode           @default(ONLINE)
  eventDate            DateTime
  eventTime            String              // e.g. "10:00 AM - 12:00 PM"
  duration             String              // e.g. "2 hours"
  venue                String              // e.g. "CSE Seminar Hall"
  googleMapsLocation   String?
  totalSeats           Int                 @default(100)
  availableSeats       Int                 @default(100)
  registrationDeadline DateTime
  status               EventStatus         @default(PUBLISHED)
  approvalStatus       EventApprovalStatus @default(PENDING)
  remarks              String?             // CDC auditor feedback remarks
  agenda               String?             // Event Agenda markdown/text
  keyBenefits          String[]            @default([])
  eligibilityCriteria  String?
  requiredDocuments    String[]            @default([])
  speakerName          String
  speakerDesignation   String?
  speakerCompany       String?
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  registrations        EventRegistration[]
  certificates         EventCertificate[]
  createdBy            User                @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([eventDate])
  @@index([isActive])
  @@index([status])
  @@index([createdAt])
  @@map("events")
}

/// Event registration — Students and Alumni can register
model EventRegistration {
  id                 String                  @id @default(uuid())
  registrationId     String                  @unique // short code or unique code
  eventId            String
  userId             String
  status             EventRegistrationStatus @default(REGISTERED)
  eventPassUrl       String?
  qrCodeUrl          String?
  attendanceMarkedAt DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  event              Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate        EventCertificate?

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("event_registrations")
}

/// One-to-one conversation between two users
model Conversation {
  id        String    @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("conversations")
}

/// Individual chat message within a conversation
model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  /// Cloudinary URL — optional image attachment
  imageUrl       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

/// In-app notifications for users
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  /// Optional deep-link within the app
  linkUrl   String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

/// Platform user roles
enum Role {
  STUDENT
  ALUMNI
  CDC
}

/// Account lifecycle status
enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

/// Mentorship request lifecycle
enum MentorshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

/// Job / internship classification
enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
  REMOTE
}

/// Job application lifecycle
enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW
  OFFERED
  REJECTED
  WITHDRAWN
}

/// Notification categories
enum NotificationType {
  MENTORSHIP_REQUEST
  MENTORSHIP_ACCEPTED
  MENTORSHIP_REJECTED
  MENTORSHIP_COMPLETED
  JOB_POSTED
  JOB_APPLICATION
  APPLICATION_UPDATE
  EVENT_CREATED
  EVENT_REMINDER
  POST_LIKE
  POST_COMMENT
  NEW_MESSAGE
  SYSTEM
}

/// Verification status for students
enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PortalApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_VERIFICATION
  APPROVED
  REJECTED
}

model StudentApplication {
  id                   String                   @id @default(uuid())
  userId               String                   @unique
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               PortalApplicationStatus  @default(DRAFT)
  remarks              String?
  submittedAt          DateTime?
  verifiedAt           DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  // Section A: Personal Information
  fullName             String
  enrollmentNumber     String
  email                String
  phone                String
  gender               String
  dateOfBirth          DateTime
  profileImage         String

  // Section B: Documents & ID Proof
  aadharNumber         String
  panCard              String?
  collegeIdNumber      String

  // Section C: Family Details
  fatherName           String
  fatherOccupation     String
  fatherPhone          String
  motherName           String
  motherOccupation     String
  motherPhone          String
  familyIncome         String
  emergencyContact     String

  // Section D: Address Details
  currentAddress       String
  currentCity          String
  currentState         String
  currentPincode       String
  permanentAddress     String
  permanentCity        String
  permanentState       String
  permanentPincode     String
  sameAsCurrent        Boolean                  @default(false)

  // Section E: Academic Record
  class10Board         String
  class10School        String
  class10Percentage    Float
  class10PassingYear   Int
  class12Board         String?
  class12School        String?
  class12Percentage    Float?
  class12PassingYear   Int?
  diplomaCollege       String?
  diplomaBranch        String?
  diplomaCGPA          Float?
  diplomaPassingYear   Int?
  currentCourse        String
  currentBranch        String
  currentSemester      Int
  currentCGPA          Float
  sgpaSemester1        Float?
  sgpaSemester2        Float?
  sgpaSemester3        Float?
  sgpaSemester4        Float?
  sgpaSemester5        Float?
  sgpaSemester6        Float?
  sgpaSemester7        Float?
  sgpaSemester8        Float?

  // Section F: Professional Profile
  careerPreference     String
  primaryDomain        String
  secondaryDomain      String?
  skills               String[]                 @default([])
  linkedinUrl          String?
  githubUrl            String?
  portfolioUrl         String?
  resumeUrl            String

  // Section G: Certifications
  certifications       ApplicationCertification[]

  @@index([status])
  @@index([createdAt])
  @@map("student_applications")
}

model ApplicationCertification {
  id                   String             @id @default(uuid())
  applicationId        String
  application          StudentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name                 String
  issuingOrganization  String
  issueDate            DateTime
  certificateUrl       String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("application_certifications")
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventRegistrationStatus {
  REGISTERED
  ATTENDED
  CANCELLED
  NO_SHOW
}

model EventCertificate {
  id             String            @id @default(uuid())
  registrationId String            @unique
  registration   EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  studentId      String
  student        User              @relation("StudentCertificates", fields: [studentId], references: [id], onDelete: Cascade)
  eventId        String
  event          Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  certificateUrl String            // SVG or PDF path / download link
  issuedAt       DateTime          @default(now())
  createdAt      DateTime          @default(now())

  @@index([studentId])
  @@index([eventId])
  @@index([createdAt])
  @@map("event_certificates")
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

enum JobApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Company {
  id              String           @id @default(uuid())
  name            String           @unique
  logoUrl         String?
  location        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  alumniProfiles  AlumniProfile[]
  workExperiences WorkExperience[]

  @@map("companies")
}

model WorkExperience {
  id              String        @id @default(uuid())
  alumniProfileId String
  alumniProfile   AlumniProfile @relation(fields: [alumniProfileId], references: [id], onDelete: Cascade)
  companyName     String
  companyId       String?
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  role            String
  startDate       DateTime
  endDate         DateTime?
  description     String?
  location        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([alumniProfileId])
  @@index([companyId])
  @@map("work_experiences")
}

model Education {
  id              String        @id @default(uuid())
  alumniProfileId String
  alumniProfile   AlumniProfile @relation(fields: [alumniProfileId], references: [id], onDelete: Cascade)
  institution     String
  degree          String
  fieldOfStudy    String?
  startDate       DateTime
  endDate         DateTime?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([alumniProfileId])
  @@map("educations")
}

model Skill {
  id             String          @id @default(uuid())
  name           String          @unique
  alumniProfiles AlumniProfile[] @relation("AlumniSkills")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("skills")
}

model Connection {
  id         String           @id @default(uuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sender     User             @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("connections")
}

model SavedAlumni {
  id        String   @id @default(uuid())
  userId    String
  alumniId  String
  createdAt DateTime @default(now())
  user      User     @relation("UserSavedAlumni", fields: [userId], references: [id], onDelete: Cascade)
  alumni    User     @relation("AlumniSavedBy", fields: [alumniId], references: [id], onDelete: Cascade)

  @@unique([userId, alumniId])
  @@map("saved_alumni")
}

