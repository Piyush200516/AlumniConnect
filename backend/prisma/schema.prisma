generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Core user model — single table for all roles with role-based auth
model User {
  id                         String                 @id @default(uuid())
  email                      String                 @unique
  password                   String
  role                       Role
  status                     AccountStatus          @default(ACTIVE)
  isEmailVerified            Boolean                @default(false)
  emailVerifyToken           String?                @unique
  emailVerifyExpiry          DateTime?
  resetToken                 String?                @unique
  resetTokenExpiry           DateTime?
  lastLoginAt                DateTime?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  alumniProfile              AlumniProfile?
  cdcProfile                 CdcProfile?
  comments                   Comment[]
  connectionsReceived        Connection[]           @relation("ConnectionReceiver")
  connectionsSent            Connection[]           @relation("ConnectionSender")
  eventCertificates          EventCertificate[]     @relation("StudentCertificates")
  eventRegistrations         EventRegistration[]
  createdEvents              Event[]
  jobApplications            JobApplication[]
  postedJobs                 Job[]
  likes                      Like[]
  mentorConnections          MentorshipConnection[] @relation("MentorConnections")
  menteeConnections          MentorshipConnection[] @relation("MenteeConnections")
  receivedMentorshipRequests MentorshipRequest[]    @relation("MentorshipAlumni")
  sentMentorshipRequests     MentorshipRequest[]    @relation("MentorshipStudent")
  sentMessages               Message[]
  notifications              Notification[]
  posts                      Post[]
  savedByUsers               SavedAlumni[]          @relation("AlumniSavedBy")
  savedAlumni                SavedAlumni[]          @relation("UserSavedAlumni")
  savedJobs                  SavedJob[]
  studentApplication         StudentApplication?
  studentProfile             StudentProfile?
  users_A                    User[]                 @relation("UserFollows")
  users_B                    User[]                 @relation("UserFollows")

  @@index([role])
  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("users")
}

/// Student profile — linked 1:1 with User (role = STUDENT)
model StudentProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  fullName           String
  enrollmentNumber   String             @unique @map("enrollmentNo")
  branch             String
  course             String
  graduationYear     Int
  skills             String[]           @default([])
  bio                String?
  profileImage       String?            @map("profileImageUrl")
  linkedinUrl        String?
  githubUrl          String?
  resumeUrl          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  isVerified         Boolean            @default(false)
  phone              String?
  verificationStatus VerificationStatus @default(PENDING)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([branch])
  @@index([graduationYear])
  @@index([course])
  @@index([createdAt])
  @@map("student_profiles")
}

/// Alumni profile — linked 1:1 with User (role = ALUMNI)
model AlumniProfile {
  id              String           @id @default(uuid())
  userId          String           @unique
  fullName        String
  passingYear     Int
  currentCompany  String?
  designation     String?
  industry        String?
  /// Years of experience
  experience      Int?
  skills          String[]         @default([])
  bio             String?
  /// Cloudinary URL
  profileImageUrl String?
  linkedinUrl     String?
  location        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  achievements    String[]         @default([])
  branch          String?
  companyId       String?
  course          String?
  currentCtc      String?
  degree          String?
  githubUrl       String?
  interests       String[]         @default([])
  phone           String?
  portfolioUrl    String?
  privacySetting  PrivacySetting   @default(PUBLIC)
  shortBio        String?          @db.VarChar(500)
  company         Company?         @relation(fields: [companyId], references: [id])
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  education       Education[]
  workExperiences WorkExperience[]
  skillsList      Skill[]          @relation("AlumniSkills")

  @@index([passingYear])
  @@index([industry])
  @@index([degree])
  @@index([skills])
  @@index([interests])
  @@index([createdAt])
  @@map("alumni_profiles")
}

/// CDC (College Development Cell) profile — linked 1:1 with User (role = CDC)
model CdcProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  collegeName   String
  department    String
  officialEmail String
  contactNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cdc_profiles")
}

/// Posts created by Alumni or CDC users
model Post {
  id        String    @id @default(uuid())
  authorId  String
  content   String
  /// Cloudinary URL
  imageUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
  likes     Like[]
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

/// Comments on posts
model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@map("comments")
}

/// Likes on posts — unique constraint prevents duplicate likes
model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

/// Mentorship request from a Student to an Alumni
model MentorshipRequest {
  id        String           @id @default(uuid())
  studentId String
  alumniId  String
  status    MentorshipStatus @default(PENDING)
  /// Optional message from student
  message   String?
  /// Optional note from alumni on accept/reject
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  alumni    User             @relation("MentorshipAlumni", fields: [alumniId], references: [id], onDelete: Cascade)
  student   User             @relation("MentorshipStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, alumniId])
  @@index([studentId])
  @@index([alumniId])
  @@index([status])
  @@index([createdAt])
  @@map("mentorship_requests")
}

/// Job or internship posted by Alumni
model Job {
  id               String            @id @default(uuid())
  postedById       String
  title            String
  description      String
  company          String
  location         String?
  salary           String?
  jobType          JobType           @default(FULL_TIME)
  skillsRequired   String[]          @default([])
  deadline         DateTime?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  applicationLink  String?
  approvalStatus   JobApprovalStatus @default(PENDING)
  benefits         String?
  companyLogo      String?
  eligibility      String?
  remarks          String?
  responsibilities String?
  selectionProcess String?
  applications     JobApplication[]
  postedBy         User              @relation(fields: [postedById], references: [id], onDelete: Cascade)
  savedBy          SavedJob[]

  @@index([postedById])
  @@index([jobType])
  @@index([isActive])
  @@index([deadline])
  @@index([createdAt(sort: Desc)])
  @@index([approvalStatus])
  @@index([isActive, approvalStatus])
  @@map("jobs")
}

/// Student application for a job
model JobApplication {
  id          String            @id @default(uuid())
  jobId       String
  applicantId String
  /// Cloudinary URL
  resumeUrl   String
  coverLetter String?
  status      ApplicationStatus @default(APPLIED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  applicant   User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
  @@index([status])
  @@index([createdAt])
  @@map("job_applications")
}

/// Events created by CDC or Alumni
model Event {
  id                   String              @id @default(uuid())
  createdById          String
  title                String
  description          String
  bannerUrl            String?
  eventDate            DateTime
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  agenda               String?
  approvalStatus       EventApprovalStatus @default(PENDING)
  availableSeats       Int                 @default(100)
  category             String
  duration             String
  eligibilityCriteria  String?
  eventTime            String
  googleMapsLocation   String?
  keyBenefits          String[]            @default([])
  mode                 EventMode           @default(ONLINE)
  registrationDeadline DateTime
  remarks              String?
  requiredDocuments    String[]            @default([])
  speakerCompany       String?
  speakerDesignation   String?
  speakerName          String
  status               EventStatus         @default(PUBLISHED)
  totalSeats           Int                 @default(100)
  venue                String
  certificates         EventCertificate[]
  registrations        EventRegistration[]
  createdBy            User                @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([eventDate])
  @@index([isActive])
  @@index([status])
  @@index([createdAt])
  @@index([approvalStatus])
  @@map("events")
}

/// Event registration — Students and Alumni can register
model EventRegistration {
  id                 String                  @id @default(uuid())
  eventId            String
  userId             String
  createdAt          DateTime                @default(now())
  attendanceMarkedAt DateTime?
  eventPassUrl       String?
  qrCodeUrl          String?
  registrationId     String                  @unique
  status             EventRegistrationStatus @default(REGISTERED)
  updatedAt          DateTime                @updatedAt
  certificate        EventCertificate?
  event              Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("event_registrations")
}

/// One-to-one conversation between two users
model Conversation {
  id           String               @id @default(uuid())
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  connectionId String               @unique
  connection   MentorshipConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@map("conversations")
}

/// Individual chat message within a conversation
model Message {
  id             String              @id @default(uuid())
  conversationId String
  senderId       String
  isRead         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  fileType       String?
  fileUrl        String?
  isResumeReview Boolean             @default(false)
  isSystem       Boolean             @default(false)
  message        String
  attachments    MessageAttachment[]
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([isRead])
  @@map("messages")
}

/// In-app notifications for users
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  /// Optional deep-link within the app
  linkUrl   String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model StudentApplication {
  id                 String                     @id @default(uuid())
  userId             String                     @unique
  status             PortalApplicationStatus    @default(DRAFT)
  remarks            String?
  submittedAt        DateTime?
  verifiedAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  fullName           String
  enrollmentNumber   String
  email              String
  phone              String
  gender             String
  dateOfBirth        DateTime
  profileImage       String
  aadharNumber       String
  panCard            String?
  collegeIdNumber    String
  fatherName         String
  fatherOccupation   String
  fatherPhone        String
  motherName         String
  motherOccupation   String
  motherPhone        String
  familyIncome       String
  emergencyContact   String
  currentAddress     String
  currentCity        String
  currentState       String
  currentPincode     String
  permanentAddress   String
  permanentCity      String
  permanentState     String
  permanentPincode   String
  sameAsCurrent      Boolean                    @default(false)
  class10Board       String
  class10School      String
  class10Percentage  Float
  class10PassingYear Int
  class12Board       String?
  class12School      String?
  class12Percentage  Float?
  class12PassingYear Int?
  diplomaCollege     String?
  diplomaBranch      String?
  diplomaCGPA        Float?
  diplomaPassingYear Int?
  currentCourse      String
  currentBranch      String
  currentSemester    Int
  currentCGPA        Float
  sgpaSemester1      Float?
  sgpaSemester2      Float?
  sgpaSemester3      Float?
  sgpaSemester4      Float?
  sgpaSemester5      Float?
  sgpaSemester6      Float?
  sgpaSemester7      Float?
  sgpaSemester8      Float?
  careerPreference   String
  primaryDomain      String
  secondaryDomain    String?
  skills             String[]                   @default([])
  linkedinUrl        String?
  githubUrl          String?
  portfolioUrl       String?
  resumeUrl          String
  certifications     ApplicationCertification[]
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("student_applications")
}

model ApplicationCertification {
  id                  String             @id @default(uuid())
  applicationId       String
  name                String
  issuingOrganization String
  issueDate           DateTime
  certificateUrl      String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  application         StudentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_certifications")
}

model EventCertificate {
  id             String            @id @default(uuid())
  registrationId String            @unique
  studentId      String
  eventId        String
  certificateUrl String
  issuedAt       DateTime          @default(now())
  createdAt      DateTime          @default(now())
  event          Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  student        User              @relation("StudentCertificates", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([eventId])
  @@index([createdAt])
  @@map("event_certificates")
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model Company {
  id              String           @id @default(uuid())
  name            String           @unique
  logoUrl         String?
  location        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  alumniProfiles  AlumniProfile[]
  workExperiences WorkExperience[]

  @@map("companies")
}

model WorkExperience {
  id              String        @id @default(uuid())
  alumniProfileId String
  companyName     String
  companyId       String?
  role            String
  startDate       DateTime
  endDate         DateTime?
  description     String?
  location        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  alumniProfile   AlumniProfile @relation(fields: [alumniProfileId], references: [id], onDelete: Cascade)
  company         Company?      @relation(fields: [companyId], references: [id])

  @@index([alumniProfileId])
  @@index([companyId])
  @@map("work_experiences")
}

model Education {
  id              String        @id @default(uuid())
  alumniProfileId String
  institution     String
  degree          String
  fieldOfStudy    String?
  startDate       DateTime
  endDate         DateTime?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  alumniProfile   AlumniProfile @relation(fields: [alumniProfileId], references: [id], onDelete: Cascade)

  @@index([alumniProfileId])
  @@map("educations")
}

model Skill {
  id             String          @id @default(uuid())
  name           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  alumniProfiles AlumniProfile[] @relation("AlumniSkills")

  @@map("skills")
}

model Connection {
  id         String           @id @default(uuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  receiver   User             @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User             @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("connections")
}

model SavedAlumni {
  id        String   @id @default(uuid())
  userId    String
  alumniId  String
  createdAt DateTime @default(now())
  alumni    User     @relation("AlumniSavedBy", fields: [alumniId], references: [id], onDelete: Cascade)
  user      User     @relation("UserSavedAlumni", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, alumniId])
  @@map("saved_alumni")
}

model MentorshipConnection {
  id           String           @id @default(uuid())
  studentId    String
  alumniId     String
  connectedAt  DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  conversation Conversation?
  meetings     Meeting[]
  alumni       User             @relation("MentorConnections", fields: [alumniId], references: [id], onDelete: Cascade)
  student      User             @relation("MenteeConnections", fields: [studentId], references: [id], onDelete: Cascade)
  resources    SharedResource[]

  @@unique([studentId, alumniId])
  @@index([studentId])
  @@index([alumniId])
  @@map("mentorship_connections")
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  fileUrl   String
  fileName  String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

model Meeting {
  id           String               @id @default(uuid())
  connectionId String
  title        String
  description  String?
  scheduledAt  DateTime
  duration     Int
  meetingLink  String?
  status       MeetingStatus        @default(SCHEDULED)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  connection   MentorshipConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@map("meetings")
}

model SharedResource {
  id           String               @id @default(uuid())
  connectionId String
  title        String
  description  String?
  fileUrl      String?
  linkUrl      String?
  sharedById   String
  createdAt    DateTime             @default(now())
  connection   MentorshipConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@map("shared_resources")
}

/// Platform user roles
enum Role {
  STUDENT
  ALUMNI
  CDC
}

/// Account lifecycle status
enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

/// Mentorship request lifecycle
enum MentorshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

/// Job / internship classification
enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
  REMOTE
}

/// Job application lifecycle
enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW
  OFFERED
  REJECTED
  WITHDRAWN
}

/// Notification categories
enum NotificationType {
  MENTORSHIP_REQUEST
  MENTORSHIP_ACCEPTED
  MENTORSHIP_REJECTED
  MENTORSHIP_COMPLETED
  JOB_POSTED
  JOB_APPLICATION
  APPLICATION_UPDATE
  EVENT_CREATED
  EVENT_REMINDER
  POST_LIKE
  POST_COMMENT
  NEW_MESSAGE
  SYSTEM
}

/// Verification status for students
enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PortalApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_VERIFICATION
  APPROVED
  REJECTED
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventRegistrationStatus {
  REGISTERED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum JobApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PrivacySetting {
  PUBLIC
  CONNECTIONS_ONLY
  HIDDEN
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
