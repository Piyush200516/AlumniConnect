// ============================================================================
// AlumniConnect — Prisma Schema
// Production-ready schema for PostgreSQL (Neon)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

/// Platform user roles
enum Role {
  STUDENT
  ALUMNI
  CDC
}

/// Account lifecycle status
enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

/// Mentorship request lifecycle
enum MentorshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

/// Job / internship classification
enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
  REMOTE
}

/// Job application lifecycle
enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW
  OFFERED
  REJECTED
  WITHDRAWN
}

/// Notification categories
enum NotificationType {
  MENTORSHIP_REQUEST
  MENTORSHIP_ACCEPTED
  MENTORSHIP_REJECTED
  MENTORSHIP_COMPLETED
  JOB_POSTED
  JOB_APPLICATION
  APPLICATION_UPDATE
  EVENT_CREATED
  EVENT_REMINDER
  POST_LIKE
  POST_COMMENT
  NEW_MESSAGE
  SYSTEM
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

/// Core user model — single table for all roles with role-based auth
model User {
  id              String        @id @default(uuid())
  email           String        @unique
  password        String
  role            Role
  status          AccountStatus @default(ACTIVE)
  isEmailVerified Boolean       @default(false)
  emailVerifyToken String?      @unique
  emailVerifyExpiry DateTime?
  resetToken      String?       @unique
  resetTokenExpiry DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // ── One-to-one profile relations (only one will be populated per user) ──
  studentProfile  StudentProfile?
  alumniProfile   AlumniProfile?
  cdcProfile      CdcProfile?

  // ── Content relations ──
  posts           Post[]
  comments        Comment[]
  likes           Like[]

  // ── Mentorship relations ──
  sentMentorshipRequests     MentorshipRequest[] @relation("MentorshipStudent")
  receivedMentorshipRequests MentorshipRequest[] @relation("MentorshipAlumni")

  // ── Job relations ──
  postedJobs      Job[]
  jobApplications JobApplication[]

  // ── Event relations ──
  createdEvents       Event[]
  eventRegistrations  EventRegistration[]

  // ── Chat relations ──
  conversationsAsUser1 Conversation[] @relation("ConversationUser1")
  conversationsAsUser2 Conversation[] @relation("ConversationUser2")
  sentMessages         Message[]

  // ── Notifications ──
  notifications   Notification[]

  @@index([role])
  @@index([status])
  @@index([email])
  @@map("users")
}

// ============================================================================
// ROLE-SPECIFIC PROFILES
// ============================================================================

/// Student profile — linked 1:1 with User (role = STUDENT)
model StudentProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  fullName        String
  enrollmentNo    String   @unique
  branch          String
  course          String
  graduationYear  Int
  skills          String[] @default([])
  bio             String?
  profileImageUrl String?  /// Cloudinary URL
  linkedinUrl     String?
  githubUrl       String?
  resumeUrl       String?  /// Cloudinary URL
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([branch])
  @@index([graduationYear])
  @@index([course])
  @@map("student_profiles")
}

/// Alumni profile — linked 1:1 with User (role = ALUMNI)
model AlumniProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  fullName        String
  passingYear     Int
  currentCompany  String?
  designation     String?
  industry        String?
  experience      Int?     /// Years of experience
  skills          String[] @default([])
  bio             String?
  profileImageUrl String?  /// Cloudinary URL
  linkedinUrl     String?
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([passingYear])
  @@index([industry])
  @@index([currentCompany])
  @@map("alumni_profiles")
}

/// CDC (College Development Cell) profile — linked 1:1 with User (role = CDC)
model CdcProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  collegeName     String
  department      String
  officialEmail   String
  contactNumber   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cdc_profiles")
}

// ============================================================================
// POST SYSTEM
// ============================================================================

/// Posts created by Alumni or CDC users
model Post {
  id        String   @id @default(uuid())
  authorId  String
  content   String
  imageUrl  String?  /// Cloudinary URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

/// Comments on posts
model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@map("comments")
}

/// Likes on posts — unique constraint prevents duplicate likes
model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

// ============================================================================
// MENTORSHIP SYSTEM
// ============================================================================

/// Mentorship request from a Student to an Alumni
model MentorshipRequest {
  id        String           @id @default(uuid())
  studentId String
  alumniId  String
  status    MentorshipStatus @default(PENDING)
  message   String?          /// Optional message from student
  note      String?          /// Optional note from alumni on accept/reject
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student User @relation("MentorshipStudent", fields: [studentId], references: [id], onDelete: Cascade)
  alumni  User @relation("MentorshipAlumni", fields: [alumniId], references: [id], onDelete: Cascade)

  @@unique([studentId, alumniId])
  @@index([studentId])
  @@index([alumniId])
  @@index([status])
  @@map("mentorship_requests")
}

// ============================================================================
// JOB PORTAL
// ============================================================================

/// Job or internship posted by Alumni
model Job {
  id             String   @id @default(uuid())
  postedById     String
  title          String
  description    String
  company        String
  location       String?
  salary         String?
  jobType        JobType  @default(FULL_TIME)
  skillsRequired String[] @default([])
  deadline       DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  postedBy     User             @relation(fields: [postedById], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([postedById])
  @@index([jobType])
  @@index([isActive])
  @@index([deadline])
  @@index([createdAt(sort: Desc)])
  @@map("jobs")
}

/// Student application for a job
model JobApplication {
  id          String            @id @default(uuid())
  jobId       String
  applicantId String
  resumeUrl   String            /// Cloudinary URL
  coverLetter String?
  status      ApplicationStatus @default(APPLIED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant User @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
  @@index([status])
  @@map("job_applications")
}

// ============================================================================
// EVENT MANAGEMENT
// ============================================================================

/// Events created by CDC or Alumni
model Event {
  id            String   @id @default(uuid())
  createdById   String
  title         String
  description   String
  bannerUrl     String?  /// Cloudinary URL
  eventDate     DateTime
  eventLocation String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy     User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@index([createdById])
  @@index([eventDate])
  @@index([isActive])
  @@map("events")
}

/// Event registration — Students and Alumni can register
model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_registrations")
}

// ============================================================================
// REAL-TIME CHAT
// ============================================================================

/// One-to-one conversation between two users
model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1    User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("conversations")
}

/// Individual chat message within a conversation
model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  imageUrl       String?  /// Cloudinary URL — optional image attachment
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

/// In-app notifications for users
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  linkUrl   String?          /// Optional deep-link within the app
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}
